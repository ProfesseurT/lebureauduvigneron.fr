# Copier ce fichier en .env et remplir les valeurs.
# NE PAS committer le fichier .env (il contient des secrets).

# Token d'intégration Notion (lecture seule)
# Créer sur : https://www.notion.so/profile/integrations
NOTION_TOKEN=

# ID de la base de données Notion "Articles Bureau du Vigneron"
# Visible dans l'URL Notion : notion.so/XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX?v=...
NOTION_DB_ID=

# Mettre à 1 pour conserver exemple-qr-code-viti.md pendant le build (test local)
KEEP_DEMO_POSTS=
