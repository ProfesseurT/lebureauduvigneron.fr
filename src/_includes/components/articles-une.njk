<section class="articles-une section" id="a-la-une">
  <div class="container--wide">

    <div class="articles-une__header">
      <h2>À la une</h2>
      <p class="articles-une__sub">Du concret. Du terrain. Pas de théorie.</p>
    </div>

    <div class="articles-une__grid">
      {% for post in collections.posts %}
        {% if loop.index <= 3 %}
        <article class="articles-une__card">
          <a href="{{ post.url }}" class="articles-une__card-link">
            <div class="articles-une__card-img">
              {% if post.data.image %}
              <img src="{{ post.data.image }}" alt="{{ post.data.title }}" loading="lazy">
              {% else %}
              <div class="articles-une__card-placeholder"></div>
              {% endif %}
            </div>
            <div class="articles-une__card-body">
              {% if post.data.pilier %}
              <p class="articles-une__pilier">{{ post.data.pilier }}</p>
              {% endif %}
              <h3 class="articles-une__title">{{ post.data.title }}</h3>
              {% if post.data.description %}
              <p class="articles-une__excerpt">{{ post.data.description }}</p>
              {% endif %}
              <p class="articles-une__meta">
                {% if post.data.temps_lecture %}{{ post.data.temps_lecture }}{% endif %}
                {% if post.data.temps_lecture and post.date %} · {% endif %}
                {% if post.date %}{{ post.date | dateReadable }}{% endif %}
              </p>
            </div>
          </a>
        </article>
        {% endif %}
      {% endfor %}

      {% set reste = 3 - (collections.posts | length) %}
      {% if reste > 0 %}
      <article class="articles-une__card articles-une__card--soon">
        <div class="articles-une__card-body articles-une__card-body--soon">
          <p class="articles-une__pilier">Bientôt</p>
          <h3 class="articles-une__title">D'autres analyses arrivent.</h3>
          <p class="articles-une__excerpt">Le Bureau démarre. Un article par semaine, sur le terrain.</p>
        </div>
      </article>
      {% endif %}
      {% if reste > 1 %}
      <article class="articles-une__card articles-une__card--soon">
        <div class="articles-une__card-body articles-une__card-body--soon">
          <p class="articles-une__pilier">Bientôt</p>
          <h3 class="articles-une__title">Le terrain, mis en mots.</h3>
          <p class="articles-une__excerpt">Visites, installations, cas concrets. Bientôt ici.</p>
        </div>
      </article>
      {% endif %}
      {% if reste > 2 %}
      <article class="articles-une__card articles-une__card--soon">
        <div class="articles-une__card-body articles-une__card-body--soon">
          <p class="articles-une__pilier">Bientôt</p>
          <h3 class="articles-une__title">La filière, vue d'en bas.</h3>
          <p class="articles-une__excerpt">Admin, marketing, outils, orga. Du vécu, pas de théorie.</p>
        </div>
      </article>
      {% endif %}
    </div>

    <div class="articles-une__cta">
      <a href="/articles/" class="btn btn--bordeaux">Voir tous les articles →</a>
    </div>

  </div>
</section>
